# ============================================================
# Kwanza Stream — Environment Variables (STAGING)
# ============================================================
# Copy to .env on the staging server. All values must be real.
# NEVER commit this file with real credentials!

# ============== CORE ==============
NODE_ENV=staging
PORT=5000
FRONTEND_URL=https://kwanza-stream-staging.vercel.app

# ============== DATABASE (managed Postgres) ==============
# Use a SEPARATE database from production!
DATABASE_URL=postgresql://kwanza_staging:PASSWORD@host:5432/kwanza_staging?schema=public&sslmode=require

# ============== REDIS (managed) ==============
REDIS_URL=redis://default:PASSWORD@host:6379

# ============== JWT ==============
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ============== EMAIL (Nodemailer) ==============
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@kwanzastream.ao
SMTP_PASS=
EMAIL_FROM=noreply@kwanzastream.ao
EMAIL_FROM_NAME=Kwanza Stream (Staging)

# ============== SMS ==============
SMS_PROVIDER=mock
# Use mock in staging to avoid real SMS costs
# Switch to 'africastalking' for SMS integration testing

# ============== PAYMENTS (Multicaixa Express) ==============
MULTICAIXA_API_URL=https://sandbox.multicaixa.co.ao
MULTICAIXA_MERCHANT_ID=
MULTICAIXA_API_KEY=
MULTICAIXA_WEBHOOK_SECRET=

# ============== STREAMING ==============
RTMP_SECRET=
FFMPEG_PATH=ffmpeg

# ============== MONITORING ==============
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
LOG_LEVEL=debug
LOG_DIR=/var/log/kwanzastream

# ============== OTP ==============
OTP_EXPIRES_IN_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_COOLDOWN_SECONDS=60
