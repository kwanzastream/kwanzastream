# ============================================================
# Kwanza Stream — Environment Variables (Production)
# ============================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git!

# ============== CORE ==============
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://app.kwanzastream.ao

# ============== DATABASE ==============
DATABASE_URL=postgresql://user:password@host:5432/kwanzastream?schema=public

# ============== REDIS ==============
REDIS_URL=redis://host:6379

# ============== JWT ==============
JWT_SECRET=generate-a-strong-random-secret-minimum-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ============== EMAIL (Nodemailer) ==============
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@kwanzastream.ao
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@kwanzastream.ao
EMAIL_FROM_NAME=Kwanza Stream

# ============== SMS PROVIDER ==============
# Options: 'mock', 'africastalking', 'twilio'
SMS_PROVIDER=africastalking

# Africa's Talking
AT_API_KEY=your-api-key
AT_USERNAME=kwanzastream

# Twilio (alternative)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ============== OTP ==============
OTP_EXPIRES_IN_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_COOLDOWN_SECONDS=60

# ============== PAYMENTS (Multicaixa Express) ==============
# Leave empty until EMIS credentials are provided
MULTICAIXA_MERCHANT_ID=
MULTICAIXA_API_KEY=
MULTICAIXA_WEBHOOK_SECRET=

# ============== LOGGING ==============
LOG_LEVEL=info
LOG_DIR=/var/log/kwanzastream
