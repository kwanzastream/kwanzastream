# Kwanza Stream — Server Environment Variables
# Copy this file to .env and fill in all values

# ============== REQUIRED ==============
DATABASE_URL=postgresql://user:password@localhost:5432/kwanza_stream
JWT_ACCESS_SECRET=       # Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=      # Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ============== RECOMMENDED ==============
FRONTEND_URL=http://localhost:3000
PORT=5000
NODE_ENV=development
RTMP_SECRET=             # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REDIS_URL=redis://localhost:6379

# ============== PAYMENTS (Multicaixa Express) ==============
MULTICAIXA_API_URL=https://api.multicaixa.co.ao
MULTICAIXA_MERCHANT_ID=
MULTICAIXA_API_KEY=
MULTICAIXA_WEBHOOK_SECRET=

# ============== SMS PROVIDER ==============
SMS_PROVIDER=mock        # Options: mock, africastalking, twilio
AT_API_KEY=              # Africa's Talking API key
AT_USERNAME=sandbox      # Africa's Talking username (use 'sandbox' for testing)

# ============== GOOGLE OAUTH ==============
GOOGLE_CLIENT_ID=        # Google Cloud Console OAuth client ID
GOOGLE_CLIENT_SECRET=    # Google Cloud Console OAuth client secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ============== WEB PUSH NOTIFICATIONS ==============
VAPID_PUBLIC_KEY=        # Generate: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@kwanzastream.com

# ============== MONITORING ==============
SENTRY_DSN=

# ============== STREAMING ==============
FFMPEG_PATH=ffmpeg       # Path to ffmpeg binary
STREAM_CDN_URL=http://localhost:8000  # CDN URL for HLS playback (use Bunny.net in prod)
STREAM_RECORDING_ENABLED=false        # Enable MP4 recording for VODs
