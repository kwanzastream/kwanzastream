generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== ENUMS ==============

enum Role {
  USER
  ADMIN
  STREAMER
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  DONATION_SENT
  DONATION_RECEIVED
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum NotificationType {
  LIVE_STARTED
  DONATION_RECEIVED
  NEW_FOLLOWER
  SYSTEM
}

enum StreamStatus {
  OFFLINE
  LIVE
  ENDED
}

// ============== MODELS ==============

model User {
  id            String   @id @default(uuid())
  phone         String   @unique
  email         String?  @unique
  passwordHash  String?
  username      String?  @unique
  displayName   String?
  avatarUrl     String?
  bannerUrl     String?
  bio           String?
  role          Role     @default(USER)
  isVerified    Boolean  @default(false)
  streamKey     String?  @unique
  interests     String[] @default([])
  onboardingCompleted Boolean @default(false)
  
  // Wallet (stored in centimos: 1 Kz = 100 centimos)
  balance       BigInt   @default(0)
  
  // Ban system
  isBanned      Boolean  @default(false)
  banReason     String?
  bannedAt      DateTime?
  
  // Email verification
  emailVerified    Boolean  @default(false)
  emailVerifyToken String?
  
  // Password recovery
  passwordResetToken   String?
  passwordResetExpires DateTime?
  
  // Legal compliance
  termsAcceptedAt    DateTime?
  minAgeConfirmedAt  DateTime?
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastLoginAt   DateTime?
  
  // Relations
  otpCodes          OtpCode[]
  refreshTokens     RefreshToken[]
  streams           Stream[]
  donationsSent     Donation[]     @relation("DonationsSent")
  donationsReceived Donation[]     @relation("DonationsReceived")
  transactions      Transaction[]
  followers         Follow[]       @relation("Following")
  following         Follow[]       @relation("Followers")
  auditLogs         AuditLog[]     @relation("AuditLogs")
  watchHistory      WatchHistory[]
  notifications     Notification[]
  favoriteCreators  FavoriteCreator[] @relation("UserFavoriteCreators")
  favoriteStreams   FavoriteStream[]  @relation("UserFavoriteStreams")
  reports           Report[]          @relation("UserReports")
  
  @@index([phone])
  @@index([email])
  @@index([username])
}

model WatchHistory {
  id        String   @id @default(uuid())
  watchedAt DateTime @default(now())
  duration  Int      @default(0) // seconds watched
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  streamId  String
  stream    Stream   @relation(fields: [streamId], references: [id], onDelete: Cascade)
  
  @@unique([userId, streamId])
  @@index([userId])
  @@index([streamId])
}

model OtpCode {
  id        String   @id @default(uuid())
  code      String
  phone     String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([phone, code])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([token])
  @@index([userId])
}

model Stream {
  id           String       @id @default(uuid())
  title        String
  description  String?
  thumbnailUrl String?
  category     String?
  status       StreamStatus @default(OFFLINE)
  viewerCount  Int          @default(0)
  peakViewers  Int          @default(0)
  
  // Timestamps
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  
  // Relations
  streamerId   String
  streamer     User         @relation(fields: [streamerId], references: [id], onDelete: Cascade)
  donations    Donation[]
  watchHistory WatchHistory[]
  
  @@index([streamerId])
  @@index([status])
  @@index([streamerId, status])  // Feed filter: streams by creator + live status
  @@index([category])            // Search by category
}

model Donation {
  id        String   @id @default(uuid())
  amount    BigInt
  saloType  String   // bronze, silver, gold, diamond, legendary
  message   String?
  createdAt DateTime @default(now())
  
  // Relations
  senderId    String
  sender      User     @relation("DonationsSent", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("DonationsReceived", fields: [receiverId], references: [id])
  streamId    String?
  stream      Stream?  @relation(fields: [streamId], references: [id])
  
  @@index([senderId])
  @@index([receiverId])
  @@index([streamId])
}

model Transaction {
  id             String            @id @default(uuid())
  amount         BigInt
  type        TransactionType
  status         TransactionStatus @default(PENDING)
  description    String?
  reference      String?           @unique
  idempotencyKey String?           @unique
  metadata       Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  // Relations
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([userId, createdAt])   // Transaction history ordered by date
}

model Follow {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  
  followerId  String
  follower    User     @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ============== AUDIT LOG ==============

enum AdminAction {
  APPROVE_WITHDRAWAL
  REJECT_WITHDRAWAL
  BAN_USER
  UNBAN_USER
  UPDATE_USER_ROLE
  END_STREAM
  DELETE_CONTENT
}

model AuditLog {
  id          String      @id @default(uuid())
  createdAt   DateTime    @default(now())
  
  adminId     String
  admin       User        @relation("AuditLogs", fields: [adminId], references: [id])
  
  action      AdminAction
  targetId    String      // ID of the affected resource (userId, transactionId, etc.)
  targetType  String      // "User", "Transaction", "Stream", etc.
  details     Json?       // Additional context (e.g., old/new values)
  ipAddress   String?
  
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

// ============== PHASE 2: NOTIFICATIONS ==============

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  body      String
  imageUrl  String?
  linkUrl   String?          // deep link, e.g. "/stream/{id}"
  read      Boolean          @default(false)
  eventId   String?          @unique  // idempotency key — prevents duplicates on retry/failure
  createdAt DateTime         @default(now())

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ============== PHASE 2: FAVORITES ==============

model FavoriteCreator {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation("UserFavoriteCreators", fields: [userId], references: [id], onDelete: Cascade)
  creatorId String

  @@unique([userId, creatorId])
  @@index([userId])
}

model FavoriteStream {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation("UserFavoriteStreams", fields: [userId], references: [id], onDelete: Cascade)
  streamId  String

  @@unique([userId, streamId])
  @@index([userId])
}

// ============== PHASE 5: REPORTS ==============

enum ReportTargetType {
  USER
  STREAM
  MESSAGE
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

model Report {
  id          String           @id @default(uuid())
  reason      String
  details     String?
  targetId    String?
  targetType  ReportTargetType @default(USER)
  status      ReportStatus     @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  reporterId  String
  reporter    User             @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([status])
  @@index([createdAt])           // Admin ordering
}
