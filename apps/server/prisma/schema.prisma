generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== ENUMS ==============

enum Role {
  USER
  ADMIN
  STREAMER
}

enum AdminRole {
  SUPER_ADMIN
  FINANCIAL_ADMIN
  CONTENT_MODERATOR
  SUPPORT_AGENT
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  DONATION_SENT
  DONATION_RECEIVED
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum NotificationType {
  LIVE_STARTED
  DONATION_RECEIVED
  NEW_FOLLOWER
  SYSTEM
}

enum StreamStatus {
  OFFLINE
  LIVE
  ENDED
}

enum ContentClassification {
  EVERYONE   // Suitable for all audiences
  TEEN       // 13+ content
  MATURE     // 18+ content
}

// ============== MODELS ==============

model User {
  id            String   @id @default(uuid())
  phone         String   @unique
  email         String?  @unique
  passwordHash  String?
  username      String?  @unique
  displayName   String?
  avatarUrl     String?
  bannerUrl     String?
  bio           String?
  role          Role     @default(USER)
  adminRole     AdminRole?
  isVerified    Boolean  @default(false)
  streamKey     String?  @unique
  interests     String[] @default([])
  // FIX: Campo de província adicionado — TestSprite #M4
  province      String?
  onboardingCompleted Boolean @default(false)
  
  // Featured & Shelf (Dashboard — Grupo 35)
  featuredMode      String   @default("auto")  // "auto" | "manual"
  featuredChannels  String[] @default([])       // ordered list of user IDs (max 10)
  shelfType         String   @default("disabled") // "channels" | "team" | "disabled"
  shelfChannels     String[] @default([])       // shelf user IDs (max 6)
  offlineBannerUrl  String?                     // custom offline banner
  trailerUrl        String?                     // channel trailer video URL
  isLive            Boolean  @default(false)    // live status flag
  
  // Google OAuth
  googleId      String?  @unique
  
  // AutoMod per-channel config
  autoModEnabled    Boolean  @default(true)
  customBannedWords String[] @default([])
  
  // Wallet (stored in centimos: 1 Kz = 100 centimos)
  balance       BigInt   @default(0)
  
  // Ban system
  isBanned      Boolean  @default(false)
  banReason     String?
  bannedAt      DateTime?
  
  // Email verification
  emailVerified    Boolean  @default(false)
  emailVerifyToken String?
  
  // Password recovery
  passwordResetToken   String?
  passwordResetExpires DateTime?
  
  // Legal compliance
  termsAcceptedAt    DateTime?
  minAgeConfirmedAt  DateTime?
  
  // KYC/AML (P0 — BNA compliance)
  kycTier            Int      @default(0) // 0=unverified, 1=phone+selfie, 2=full ID
  kycSubmittedAt     DateTime?
  kycApprovedAt      DateTime?
  kycDocumentUrl     String?
  dailyTransacted    BigInt   @default(0)
  lastTransactedDate DateTime?
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastLoginAt   DateTime?
  
  // Relations
  otpCodes          OtpCode[]
  refreshTokens     RefreshToken[]
  streams           Stream[]
  donationsSent     Donation[]     @relation("DonationsSent")
  donationsReceived Donation[]     @relation("DonationsReceived")
  transactions      Transaction[]
  followers         Follow[]       @relation("Following")
  following         Follow[]       @relation("Followers")
  auditLogs         AuditLog[]     @relation("AuditLogs")
  watchHistory      WatchHistory[]
  notifications     Notification[]
  favoriteCreators  FavoriteCreator[] @relation("UserFavoriteCreators")
  favoriteStreams   FavoriteStream[]  @relation("UserFavoriteStreams")
  reports           Report[]          @relation("UserReports")
  clips             Clip[]            @relation("UserClips")
  events            Event[]           @relation("UserEvents")
  eventRsvps        EventRSVP[]
  pushSubscriptions PushSubscription[]
  conversationsA    Conversation[]     @relation("ConversationsA")
  conversationsB    Conversation[]     @relation("ConversationsB")
  sentMessages      DirectMessage[]    @relation("SentMessages")
  subscriptions     Subscription[]     @relation("Subscriptions")
  subscribers       Subscription[]     @relation("Subscribers")
  vods              Vod[]              @relation("UserVods")
  radioConfig       RadioConfig?
  radioSchedules    RadioSchedule[]
  campProgress      UserCampProgress[]
  campCertificates  CampCertificate[]
  adCampaigns       AdCampaign[]
  developerApps     DeveloperApp[]
  awardsVotes       AwardsVote[]
  adminAuditLogs    AdminAuditLog[]
  adminSessions     AdminSession[]
  supportTickets    SupportTicket[]
  viewHistory       ViewHistory[]
  searchHistory     SearchHistory[]
  channelVisits     ChannelVisitHistory[]
  savedItems        SavedItem[]
  collections       Collection[]
  favoriteItems     FavoriteItem[]
  watchParties      WatchParty[]
  watchPartyJoins   WatchPartyParticipant[]
  referralCode      ReferralCode?
  referralsMade     Referral[]     @relation("referrer")
  referredBy        Referral?      @relation("referred")
  
  @@index([phone])
  @@index([email])
  @@index([username])
}

model WatchHistory {
  id        String   @id @default(uuid())
  watchedAt DateTime @default(now())
  duration  Int      @default(0) // seconds watched
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  streamId  String
  stream    Stream   @relation(fields: [streamId], references: [id], onDelete: Cascade)
  
  @@unique([userId, streamId])
  @@index([userId])
  @@index([streamId])
}

model OtpCode {
  id        String   @id @default(uuid())
  code      String
  phone     String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([phone, code])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([token])
  @@index([userId])
}

model Stream {
  id           String       @id @default(uuid())
  title        String
  description  String?
  thumbnailUrl String?
  category     String?
  contentClassification ContentClassification @default(EVERYONE)
  status       StreamStatus @default(OFFLINE)
  viewerCount  Int          @default(0)
  peakViewers  Int          @default(0)
  
  // Timestamps
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  
  // Relations
  streamerId   String
  streamer     User         @relation(fields: [streamerId], references: [id], onDelete: Cascade)
  donations    Donation[]
  watchHistory WatchHistory[]
  clips        Clip[]
  events       Event[]
  vods         Vod[]
  
  @@index([streamerId])
  @@index([status])
  @@index([streamerId, status])  // Feed filter: streams by creator + live status
  @@index([category])            // Search by category
}

model Donation {
  id        String   @id @default(uuid())
  amount    BigInt
  saloType  String   // bronze, silver, gold, diamond, legendary
  message   String?
  createdAt DateTime @default(now())
  
  // Relations
  senderId    String
  sender      User     @relation("DonationsSent", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("DonationsReceived", fields: [receiverId], references: [id])
  streamId    String?
  stream      Stream?  @relation(fields: [streamId], references: [id])
  
  @@index([senderId])
  @@index([receiverId])
  @@index([streamId])
}

model Transaction {
  id             String            @id @default(uuid())
  amount         BigInt
  type        TransactionType
  status         TransactionStatus @default(PENDING)
  description    String?
  reference      String?           @unique
  idempotencyKey String?           @unique
  metadata       Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  // Relations
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  ledgerEntries LedgerEntry[]
  
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([userId, createdAt])   // Transaction history ordered by date
}

model Follow {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  
  followerId  String
  follower    User     @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ============== AUDIT LOG ==============

enum AdminAction {
  APPROVE_WITHDRAWAL
  REJECT_WITHDRAWAL
  BAN_USER
  UNBAN_USER
  UPDATE_USER_ROLE
  END_STREAM
  DELETE_CONTENT
  CHAT_TIMEOUT
  CHAT_BAN
}

model AuditLog {
  id          String      @id @default(uuid())
  createdAt   DateTime    @default(now())
  
  adminId     String
  admin       User        @relation("AuditLogs", fields: [adminId], references: [id])
  
  action      AdminAction
  targetId    String      // ID of the affected resource (userId, transactionId, etc.)
  targetType  String      // "User", "Transaction", "Stream", etc.
  details     Json?       // Additional context (e.g., old/new values)
  ipAddress   String?
  
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

// ============== PHASE 2: NOTIFICATIONS ==============

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  body      String
  imageUrl  String?
  linkUrl   String?          // deep link, e.g. "/stream/{id}"
  read      Boolean          @default(false)
  eventId   String?          @unique  // idempotency key — prevents duplicates on retry/failure
  createdAt DateTime         @default(now())

  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ============== PHASE 2: FAVORITES ==============

model FavoriteCreator {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation("UserFavoriteCreators", fields: [userId], references: [id], onDelete: Cascade)
  creatorId String

  @@unique([userId, creatorId])
  @@index([userId])
}

model FavoriteStream {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation("UserFavoriteStreams", fields: [userId], references: [id], onDelete: Cascade)
  streamId  String

  @@unique([userId, streamId])
  @@index([userId])
}

// ============== PHASE 5: REPORTS ==============

enum ReportTargetType {
  USER
  STREAM
  MESSAGE
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

model Report {
  id          String           @id @default(uuid())
  reason      String
  details     String?
  targetId    String?
  targetType  ReportTargetType @default(USER)
  status      ReportStatus     @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  reporterId  String
  reporter    User             @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([status])
  @@index([createdAt])           // Admin ordering
}

// ============== P0: DOUBLE-ENTRY LEDGER ==============

model LedgerEntry {
  id             String   @id @default(uuid())
  transactionId  String
  transaction    Transaction @relation(fields: [transactionId], references: [id])
  accountId      String   // userId or "platform" or "escrow"
  accountType    String   // "user" | "platform" | "escrow"
  debit          BigInt   @default(0)
  credit         BigInt   @default(0)
  balance        BigInt   // running balance after this entry
  description    String?
  createdAt      DateTime @default(now())

  @@index([accountId, createdAt])
  @@index([transactionId])
  @@index([accountType])
}

// ============== P0: WEBHOOK EVENT LOG ==============

model WebhookEventLog {
  id              String   @id @default(uuid())
  provider        String   // "multicaixa" | "emis" | "unitel_money"
  eventType       String   // "payment.completed" | "payment.failed" etc.
  payload         Json
  signature       String?
  processed       Boolean  @default(false)
  processingError String?
  idempotencyKey  String?  @unique
  httpStatus      Int?     // response status we returned
  createdAt       DateTime @default(now())

  @@index([provider, createdAt])
  @@index([idempotencyKey])
  @@index([processed])
}

// ============== P1: CLIPS SYSTEM ==============

model Clip {
  id           String   @id @default(uuid())
  title        String
  thumbnailUrl String?
  duration     Int      // seconds
  startTime    Int      // offset in seconds from stream start
  endTime      Int      // offset in seconds from stream start
  viewCount    Int      @default(0)
  shareCount   Int      @default(0)
  videoUrl     String?  // processed clip URL (Cloudflare Stream or local)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Who created the clip
  creatorId    String
  creator      User     @relation("UserClips", fields: [creatorId], references: [id], onDelete: Cascade)

  // Which stream was clipped
  streamId     String
  stream       Stream   @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@index([creatorId, createdAt])
  @@index([streamId])
  @@index([viewCount])  // Trending clips
}

// ============== P2: EVENTS SYSTEM ==============

model Event {
  id           String      @id @default(uuid())
  title        String
  description  String?
  coverUrl     String?
  category     String?     // "música", "gaming", "educação", etc.
  scheduledAt  DateTime    // When the event starts
  endsAt       DateTime?   // Optional end time
  status       EventStatus @default(SCHEDULED) // SCHEDULED, LIVE, ENDED, CANCELLED
  rsvpCount    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Organizer
  organizerId  String
  organizer    User        @relation("UserEvents", fields: [organizerId], references: [id], onDelete: Cascade)

  // Optional linked stream
  streamId     String?
  stream       Stream?     @relation(fields: [streamId], references: [id], onDelete: SetNull)

  // RSVPs
  rsvps        EventRSVP[]

  @@index([organizerId, scheduledAt])
  @@index([scheduledAt])
  @@index([status])
}

model EventRSVP {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])  // One RSVP per user per event
}

enum EventStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

// ============== PUSH NOTIFICATIONS ==============

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String   // VAPID public key
  auth      String   // VAPID auth key
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============== DIRECT MESSAGING ==============

model Conversation {
  id            String    @id @default(uuid())
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Participants (exactly 2 users)
  participantA  String
  userA         User      @relation("ConversationsA", fields: [participantA], references: [id], onDelete: Cascade)
  participantB  String
  userB         User      @relation("ConversationsB", fields: [participantB], references: [id], onDelete: Cascade)

  messages      DirectMessage[]

  @@unique([participantA, participantB])
  @@index([participantA, lastMessageAt])
  @@index([participantB, lastMessageAt])
}

model DirectMessage {
  id             String       @id @default(uuid())
  content        String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ============== SUBSCRIPTIONS ==============

enum SubscriptionTier {
  FREE
  SUPPORTER  // basic tier
  VIP        // premium tier
}

model Subscription {
  id          String           @id @default(uuid())
  tier        SubscriptionTier @default(FREE)
  active      Boolean          @default(true)
  startedAt   DateTime         @default(now())
  expiresAt   DateTime?
  autoRenew   Boolean          @default(false)
  amount      BigInt           @default(0) // monthly price in Kz
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Subscriber
  subscriberId String
  subscriber   User    @relation("Subscriptions", fields: [subscriberId], references: [id], onDelete: Cascade)

  // Creator being subscribed to
  creatorId    String
  creator      User    @relation("Subscribers", fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, creatorId])
  @@index([creatorId, active])
  @@index([subscriberId, active])
  @@index([expiresAt])
}

// ============== VOD / REPLAYS ==============

model Vod {
  id           String    @id @default(uuid())
  title        String
  description  String?
  thumbnailUrl String?
  videoUrl     String    // stored video URL
  duration     Int       @default(0) // seconds
  viewCount    Int       @default(0)
  isPublic     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Source stream
  streamId     String?
  stream       Stream?   @relation(fields: [streamId], references: [id], onDelete: SetNull)

  // Creator
  creatorId    String
  creator      User      @relation("UserVods", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, createdAt])
  @@index([viewCount])
}

// ============== RADIO CONFIG (Grupo 37) ==============

model RadioConfig {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  programName   String?
  description   String?
  primaryGenre  String?
  extraGenres   String[] @default([])
  quality       Int      @default(128) // kbps: 64, 128, 320
  artworkUrl    String?
  streamKey     String   @unique @default(cuid())
  isEnabled     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RadioSchedule {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek       Int      // 0=Dom, 1=Seg, ..., 6=Sáb
  startHour       Int      // hora WAT (0-23)
  durationMin     Int      // duração em minutos
  notifyFollowers Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([userId, dayOfWeek])
}

// ============== KWANZA CAMP (Grupo 38) ==============

model UserCampProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapterSlug String   // ex: "nivel-1/primeiro-stream/cap-2"
  completedAt DateTime @default(now())

  @@unique([userId, chapterSlug])
  @@index([userId])
}

model CampCertificate {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  level    Int      // 1, 2, 3
  issuedAt DateTime @default(now())
  certCode String   @unique // "KWC-2026-001234"

  @@index([userId])
}

// ============== ADS & MARCAS (Grupo 39) ==============

model AdCampaign {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  objective        String   // "awareness" | "drops" | "conversion" | "sponsorship"
  status           String   @default("draft") // "draft" | "review" | "active" | "paused" | "completed"
  budget           Float    // Kz
  spent            Float    @default(0)
  startDate        DateTime
  endDate          DateTime
  targetProvinces  String[] @default([])
  targetCategories String[] @default([])
  targetInterests  String[] @default([])
  creativeUrl      String?
  destinationUrl   String?
  ctaText          String?
  impressions      Int      @default(0)
  clicks           Int      @default(0)
  reference        String   @unique // "ADS-2026-00234"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============== DEVELOPERS (Grupo 40) ==============

model DeveloperApp {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  clientId      String   @unique
  clientSecret  String
  status        String   @default("sandbox") // "sandbox" | "review" | "production" | "suspended"
  category      String   @default("other") // "bot" | "overlay" | "dashboard" | "mobile" | "other"
  websiteUrl    String?
  privacyUrl    String?
  tosUrl        String?
  redirectUris  String[] @default([])
  logoUrl       String?
  webhooks      DeveloperWebhook[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([clientId])
}

model DeveloperWebhook {
  id           String       @id @default(cuid())
  appId        String
  app          DeveloperApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  url          String
  events       String[]     @default([])
  secret       String
  isActive     Boolean      @default(true)
  lastDelivery DateTime?
  createdAt    DateTime     @default(now())

  @@index([appId])
}

// ============== ANGOLA-FIRST (Grupo 41) ==============

model AwardsNominee {
  id        String   @id @default(cuid())
  year      Int
  category  String
  channelId String
  votes     Int      @default(0)
  isWinner  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([year, category])
}

model AwardsVote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year      Int
  category  String
  nomineeId String
  createdAt DateTime @default(now())

  @@unique([userId, year, category])
}

model EducationWorkshop {
  id            String   @id @default(cuid())
  title         String
  description   String
  date          DateTime
  registrations String[] @default([])
  maxAttendees  Int      @default(50)
  createdAt     DateTime @default(now())
}

// ============== ADMIN PANEL (Grupo 42) ==============

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action     String
  targetId   String?
  targetType String?
  details    Json?
  ip         String
  timestamp  DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([timestamp])
}

model AdminSession {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  ip        String
  userAgent String   @default("")
  createdAt DateTime @default(now())
  expiresAt DateTime
  lastSeen  DateTime @updatedAt

  @@index([adminId])
}

// ============== GRUPO 43: Suporte ==============

model SupportTicket {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reference   String          @unique
  category    String
  subject     String
  status      String          @default("open")
  priority    String          @default("normal")
  messages    TicketMessage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([reference])
}

model TicketMessage {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String
  isAdmin     Boolean       @default(false)
  content     String
  attachments String[]
  createdAt   DateTime      @default(now())

  @@index([ticketId])
}

// ============== GRUPO 45: Histórico ==============

model ViewHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId   String
  contentType String
  watchedAt   DateTime @default(now())
  watchedSecs Int      @default(0)
  progress    Float    @default(0)

  @@index([userId, watchedAt])
  @@unique([userId, contentId])
}

model SearchHistory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query      String
  searchedAt DateTime @default(now())

  @@index([userId, searchedAt])
}

model ChannelVisitHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId String
  visitedAt DateTime @default(now())

  @@unique([userId, channelId])
  @@index([userId, visitedAt])
}

// ============== GRUPO 46: Guardados & Favoritos ==============

model SavedItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId   String
  contentType String
  savedAt     DateTime @default(now())
  collections CollectionItem[]

  @@unique([userId, contentId, contentType])
  @@index([userId, contentType])
}

model Collection {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isPublic    Boolean          @default(false)
  items       CollectionItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  savedItemId  String
  savedItem    SavedItem  @relation(fields: [savedItemId], references: [id], onDelete: Cascade)
  addedAt      DateTime   @default(now())

  @@unique([collectionId, savedItemId])
}

model FavoriteItem {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetId   String
  targetType String
  addedAt    DateTime @default(now())

  @@unique([userId, targetId, targetType])
}

// ============== GRUPO 47: Watch Party ==============

model WatchParty {
  id              String   @id @default(cuid())
  code            String   @unique
  hostId          String
  host            User     @relation(fields: [hostId], references: [id], onDelete: Cascade)
  streamId        String?
  name            String?
  isPublic        Boolean  @default(false)
  maxParticipants Int      @default(10)
  status          String   @default("active")
  participants    WatchPartyParticipant[]
  createdAt       DateTime @default(now())
  endedAt         DateTime?
}

model WatchPartyParticipant {
  id       String     @id @default(cuid())
  partyId  String
  party    WatchParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime   @default(now())
  leftAt   DateTime?
  isOnline Boolean    @default(true)

  @@unique([partyId, userId])
}

// ============== GRUPO 48: Referral ==============

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String   @unique
  clicks    Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  referrals Referral[]
}

model Referral {
  id            String       @id @default(cuid())
  referrerId    String
  referrer      User         @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId    String       @unique
  referred      User         @relation("referred", fields: [referredId], references: [id], onDelete: Cascade)
  codeId        String
  code          ReferralCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  status        String       @default("pending")
  referrerSalos Int          @default(200)
  referredSalos Int          @default(100)
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
}

// ============== GRUPO 49: App Download ==============

model IosWaitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ============== PRE-LAUNCH EMAIL CAPTURE ==============

model PreLaunchSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("web")   // "web" | "whatsapp" | "social"
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}
