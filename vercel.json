{
    "version": 2,
    "buildCommand": "cd apps/web && npm run build",
    "outputDirectory": "apps/web/.next",
    "framework": "nextjs",
    "installCommand": "cd apps/web && npm install",
    "env": {
        "NEXT_PUBLIC_API_URL": "@api_url"
    },
    "headers": [
        {
            "source": "/sw-push.js",
            "headers": [
                {
                    "key": "Service-Worker-Allowed",
                    "value": "/"
                },
                {
                    "key": "Cache-Control",
                    "value": "no-cache"
                }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://api.kwanzastream.com/api/:path*"
        }
    ]
}