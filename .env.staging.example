# ============================================================
# Kwanza Stream — Staging Environment Variables
# Copy to .env and fill in real values before deploying
# ============================================================

# ============== Database ==============
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql://kwanza:CHANGE_ME_strong_password_here@postgres:5432/kwanza_staging

# ============== Redis ==============
REDIS_URL=redis://redis:6379
# For Upstash (production):
# REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@YOUR_UPSTASH_HOST:6379

# ============== Auth Secrets ==============
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_generate_random_64_bytes
JWT_REFRESH_SECRET=CHANGE_ME_generate_random_64_bytes

# ============== URLs ==============
FRONTEND_URL=https://kwanza-stream.vercel.app
# For local staging:
# FRONTEND_URL=http://localhost:3000

# ============== Payment Webhooks ==============
MULTICAIXA_WEBHOOK_SECRET=CHANGE_ME_from_multicaixa_dashboard

# ============== Monitoring ==============
SENTRY_DSN=
# Get from https://sentry.io → Kwanza Stream project

# ============== Cloudflare Stream (optional) ==============
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_STREAM_SIGNING_KEY=

# ============== Node ==============
NODE_ENV=staging
PORT=5000
